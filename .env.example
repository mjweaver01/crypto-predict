# ── Bitcoin Predict — environment variables ─────────────────────────────────
# Copy to .env. Everything has a sensible default; the app runs with NO keys
# (pure statistical model against Binance public data).

# ── Server ───────────────────────────────────────────────────────────────────
# 8333 is Bitcoin's default P2P network port.
PORT=8333

# ── Price data (Binance public API — no key required) ──────────────────────────
# The Polymarket BTC markets resolve on Binance BTC/USDT, so we read from there.
# data-api.binance.vision is the public market-data mirror (no geo-block / no key).
# Use https://api.binance.com only where it isn't legally restricted.
BINANCE_BASE_URL=https://data-api.binance.vision
BTC_SYMBOL=BTCUSDT

# ── Multi-crypto ───────────────────────────────────────────────────────────────
# All six Polymarket crypto up/down assets (btc,eth,sol,xrp,doge,bnb) are
# predicted and committed automatically.
# Cryptos allowed to REAL-trade (TRADING_ENABLED). Only btc has a track record;
# let the others accumulate a paper history before adding them.
TRADE_CRYPTOS=btc

# ── Cache TTLs (seconds) ───────────────────────────────────────────────────────
# Price/kline fetches are cached briefly so a 5s dashboard poll stays cheap.
CACHE_TTL_KLINES=20
# How long a computed prediction is cached (keep low for a live feel).
CACHE_TTL_PREDICT=20

# ── Learned layer (per-family ridge logistic on raw prob + features) ──────────
# Resolved committed calls required before the learned layer activates at all.
CALIB_MIN_SAMPLES=25
# L2 prior pulling (w0, b) toward the identity calibrator. Higher = stiffer.
CALIB_PRIOR=10
# L2 prior pulling feature weights (momentum, market, regime, …) toward 0.
CALIB_FEATURE_PRIOR=10
# Recency half-life per family (hours): a sample this old counts half as much,
# so a fitted regime bias decays instead of lingering by dilution.
CALIB_HALF_LIFE_HOURS_5M=24
CALIB_HALF_LIFE_HOURS_15M=48
CALIB_HALF_LIFE_HOURS_1H=168
CALIB_HALF_LIFE_HOURS_1D=1440

# ── Paper-trading realism ──────────────────────────────────────────────────────
# Hard dollar cap on the REQUESTED paper bet before depth. The actual stake is
# then walked against the stored book depth (bounded by PAPER_FILL_SLIPPAGE), so
# the recorded fill — and the live verdict's stake — is only ever what the book
# could absorb. This cap mainly bounds the request on the rare deep book.
PAPER_MAX_STAKE_USD=100
# Max price deterioration past the touch a simulated fill may walk into the
# stored book depth.
PAPER_FILL_SLIPPAGE=0.01
# Stake for the non-compounding flat-stake scoreboard (the extrapolation-safe
# number reported in /api/paper summary.flat).
PAPER_FLAT_STAKE_USD=10
# Taker fee (basis points) applied to every cost/edge/P&L number. Defaults by
# platform: Polymarket 1000 (10%, taken in shares), Kalshi 700 (7% quadratic —
# fee = rate·p·(1−p) in cash; PAPER_FEE_MODEL=shares|quadratic overrides the
# formula). The live executor reads the real rate from the venue per trade;
# these knobs only feed the paper replay. Never zero them to make a backtest
# look better.
PAPER_TAKER_FEE_BPS=1000
PAPER_FEE_MODEL=

# ── Trading platform ───────────────────────────────────────────────────────────
# Which prediction market to quote and trade on: polymarket (default) or
# kalshi. Kalshi is CFTC-regulated and legal to trade from the US; it runs the
# 15m up/down family for all six assets (no 5m/4h equivalent — those families
# still predict, they just have no live market). Quotes, strikes, fees, and
# execution all switch together; historical ledger rows keep resolving against
# whichever platform they were recorded on.
TRADING_PLATFORM=polymarket
# Kalshi credentials (only needed for LIVE trading on kalshi; quotes and
# dry-run need none). Create an API key at kalshi.com → account → API keys:
# you get a key id (UUID) and download an RSA private key once.
KALSHI_API_KEY_ID=
# The RSA key as one line with \n escapes, OR a path to the .pem file.
KALSHI_PRIVATE_KEY=
KALSHI_PRIVATE_KEY_PATH=
# Kalshi trade API base (override for the demo environment:
# https://demo-api.kalshi.co/trade-api/v2).
KALSHI_API_URL=https://api.elections.kalshi.com/trade-api/v2

# ── Live trading (REAL MONEY — read carefully) ────────────────────────────────
# Off by default. The full path is: enable → shadow (dry-run) → go live.
# On TRADING_PLATFORM=kalshi, skip the wallet steps: fund your Kalshi account,
# set the two KALSHI_* credentials above, and go enable → shadow → live.
#
#   1. Create a DEDICATED Polygon wallet for the bot (never your main wallet),
#      fund it with USDC.e (bridged USDC) + a little POL for gas, and put its
#      private key below.
#   2. bun run trade:setup     (derives CLOB API creds, sets allowances)
#   3. TRADING_ENABLED=true with TRADING_DRY_RUN=true → full decision path,
#      simulated fills recorded to data/trades.json. Watch /api/trades.
#   4. Only when the shadow record looks right: TRADING_DRY_RUN=false.
TRADING_ENABLED=false
TRADING_DRY_RUN=true
# Hex private key of the dedicated trading wallet (dry-run works without it).
POLYMARKET_PRIVATE_KEY=
# 0 = plain EOA wallet (recommended for a bot). 1 = Magic/email proxy,
# 2 = browser-wallet proxy — those also need POLYMARKET_FUNDER (the proxy
# address shown as your Polymarket deposit address) and claim winnings via the
# Polymarket UI (auto-redeem is EOA-only).
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_FUNDER=
# Which families may trade. Only 5m has measured tradable edge; widen with
# care. (On TRADING_PLATFORM=kalshi the default is 15m — the only family it
# runs.)
TRADE_FAMILIES=5m
# Sizing: fractional Kelly (PAPER_KELLY_FRACTION/PAPER_MAX_STAKE_FRACTION apply)
# against min(USDC balance, TRADE_BANKROLL_CAP_USD), hard-capped per trade.
TRADE_BANKROLL_CAP_USD=250
TRADE_MAX_STAKE_USD=10
TRADE_MIN_STAKE_USD=1
# Skip if the live ask is worse than the commit-time cost by more than this.
TRADE_MAX_SLIPPAGE=0.01
# Max concurrently open positions.
TRADE_MAX_OPEN=4
# Halt new trades for the rest of the UTC day after this much realized loss.
TRADE_DAILY_LOSS_LIMIT_USD=25
# Automatically redeem winning positions back into USDC (EOA mode only).
TRADE_AUTO_REDEEM=true
# Polygon RPC for allowances + redemption (any public endpoint works).
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
