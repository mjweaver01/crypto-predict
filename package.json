{
  "name": "bitcoin-predict",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "start": "bun run src/server/index.ts",
    "backtest": "bun run scripts/backtest.ts",
    "backtest:market": "bun run scripts/backtest-market.ts",
    "backfill": "bun run scripts/backfill.ts",
    "build:client": "bun build src/client/live.ts src/client/history.ts --outdir public/dist --target browser",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts",
    "lint:fix": "eslint src scripts --fix",
    "format": "prettier --write src scripts",
    "format:check": "prettier --check src scripts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/openai": "^3.0.68",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "ai": "^6.0.197",
    "zod": "^4.4.3"
  }
}
