{
  "name": "bitcoin-predict",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "start": "bun run src/server/index.ts",
    "backtest": "bun run scripts/backtest.ts",
    "backtest:market": "bun run scripts/backtest-market.ts",
    "backfill": "bun run scripts/backfill.ts",
    "backfill:gaps": "bun run scripts/backfill-gaps.ts",
    "backfill:book": "bun run scripts/backfill-book.ts",
    "edge": "bun run scripts/edge-report.ts",
    "trade:setup": "bun run scripts/trade-setup.ts",
    "trade:check": "bun run scripts/trade-setup.ts --check",
    "trade:redeem": "bun run scripts/trade-redeem.ts",
    "trade:verify": "bun run scripts/trade-verify.ts",
    "build:client": "bun build src/client/live.tsx src/client/history.tsx --outdir public/dist --target browser",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts",
    "lint:fix": "eslint src scripts --fix",
    "format": "prettier --write src scripts",
    "format:check": "prettier --check src scripts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.8.1",
    "@preact/signals": "^2.9.1",
    "ethers": "5.8.0",
    "preact": "^10.29.2"
  }
}
